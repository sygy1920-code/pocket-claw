{
  "name": "pocket-claw",
  "version": "1.0.0",
  "description": "A desktop pet application built with Electron and Live2D",
  "main": "out/main/index.js",
  "electron": {
    "main": "electron/main/index.ts"
  },
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:clean": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "start": "electron-vite dev",
    "reset-memory": "node scripts/reset-memory.js"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "live2d"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/three": "^0.169.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.yourname.pocket-claw",
    "productName": "Pocket Claw",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "src/resource/**/*",
      "icons/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
